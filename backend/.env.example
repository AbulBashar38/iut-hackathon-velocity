# Server environment
NODE_ENV=development

# Port the API + Socket.io server listens on
PORT=6006

# Allowed origin for CORS and Socket.io (the frontend dev server)
CLIENT_ORIGIN=http://localhost:5173

# --- Discord bot (optional) ---
# Leave DISCORD_BOT_TOKEN empty to disable the bot entirely.
DISCORD_BOT_TOKEN=
DISCORD_COMMAND_PREFIX=!

# --- LLM (optional) ---
# Leave GEMINI_API_KEY empty to fall back to deterministic responses.
GEMINI_API_KEY=
LLM_MODEL=gemini-1.5-flash
